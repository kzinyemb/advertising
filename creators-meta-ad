    <script>
        // Sync values from input boxes on state mutation to the ad UI mockup
        function syncPreview() {
            const headlineText = document.getElementById('input-headline').value;
            const bodyText = document.getElementById('input-body').value;
            const linkText = document.getElementById('input-link').value;
            const footerText = document.getElementById('input-footer').value;

            // Update DOM Node properties
            document.getElementById('preview-body-headline').innerText = headlineText;
            document.getElementById('preview-card-headline').innerText = "🛡️ Secure Your " + headlineText.replace(/[.!?]/g, '') + " Token";
            document.getElementById('preview-body-content').innerText = bodyText;
            document.getElementById('preview-body-link').innerText = linkText;
            document.getElementById('preview-card-url-display').innerText = footerText.toUpperCase();
        }

        // Toggle mobile mock smartphone views to responsive desktop grids
        function setViewport(target) {
            const wrapper = document.getElementById('device-wrapper');
            const phoneBtn = document.getElementById('btn-phone');
            const tabletBtn = document.getElementById('btn-tablet');

            if(target === 'phone') {
                wrapper.className = 'w-full max-w-[450px] transition-all duration-500 ease-out';
                phoneBtn.className = 'px-4 py-2 rounded-lg text-xs font-semibold flex items-center gap-2 transition-all bg-brand-creator text-white shadow-sm';
                tabletBtn.className = 'px-4 py-2 rounded-lg text-xs font-semibold flex items-center gap-2 transition-all text-slate-400 hover:text-white';
            } else {
                wrapper.className = 'w-full max-w-full lg:max-w-[800px] transition-all duration-500 ease-out';
                tabletBtn.className = 'px-4 py-2 rounded-lg text-xs font-semibold flex items-center gap-2 transition-all bg-brand-creator text-white shadow-sm';
                phoneBtn.className = 'px-4 py-2 rounded-lg text-xs font-semibold flex items-center gap-2 transition-all text-slate-400 hover:text-white';
            }
        }

        // Toggle feed dark vs light modes to replicate real-app aesthetics
        function toggleTheme() {
            const htmlNode = document.documentElement;
            htmlNode.classList.toggle('dark');
        }

        // Initialize animated simulation loop for Terminal log metrics
        function startTerminalSimulation() {
            const row1 = document.getElementById('log-line-1');
            const row2 = document.getElementById('log-line-2');
            const row3 = document.getElementById('log-line-3');
            const row4 = document.getElementById('log-line-4');

            function cycle() {
                // Clear previous states
                row1.style.opacity = '0';
                row2.style.opacity = '0';
                row3.style.opacity = '0';
                row4.style.opacity = '0';

                // Sequence triggers
                setTimeout(() => { row1.style.opacity = '1'; }, 500);
                setTimeout(() => { row2.style.opacity = '1'; }, 1300);
                setTimeout(() => { row3.style.opacity = '1'; }, 2100);
                setTimeout(() => { row4.style.opacity = '1'; }, 3000);
                
                // Restart cycle at 6 second intervals
                setTimeout(cycle, 6000);
            }
            cycle();
        }

        // Boot system components
        window.onload = function() {
            // Apply dark mode theme matching standard workspace defaults
            document.documentElement.classList.add('dark');
            syncPreview();
            startTerminalSimulation();
        }
    </script>
